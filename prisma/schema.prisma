generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int           @id @default(autoincrement())
  username  String        @unique
  password  String
  coins     Int           @default(0)
  createdAt DateTime      @default(now())
  players   UserPlayer[]
  matches   Match[]
}

model UserPlayer {
  id         Int      @id @default(autoincrement())
  userId     Int
  playerId   Int
  source     String   // pack | mission | objective
  acquiredAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, playerId])
}

model Match {
  id           Int               @id @default(autoincrement())
  userId       Int
  result       String            // win | draw | loss
  goalsFor     Int
  goalsAgainst Int
  coinsEarned  Int               @default(0)
  playedAt     DateTime          @default(now())
  user         User              @relation(fields: [userId], references: [id])
  playerStats  MatchPlayerStat[]
}

model MatchPlayerStat {
  id          Int     @id @default(autoincrement())
  matchId     Int
  playerId    Int
  goals       Int     @default(0)
  assists     Int     @default(0)
  cleanSheet  Boolean @default(false)
  yellowCards Int     @default(0)  // 0, 1 ou 2
  redCard     Boolean @default(false)
  rating      Float
  isMVP       Boolean @default(false)
  match       Match   @relation(fields: [matchId], references: [id])
}
